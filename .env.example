# PostgreSQL
POSTGRES_DB=envoydb
POSTGRES_USER=envoy
POSTGRES_PASSWORD=change_me_in_production

# Redis
REDIS_URL=redis://redis:6379

# Google Cloud
GCP_PROJECT_ID=envoylabs
GCS_BUCKET_NAME=envoylabs-media
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Application
NODE_ENV=production
API_PORT=4000
FRONTEND_PORT=3000
REALTIME_PORT=4001

# Domains
DOMAIN=envoylabs.us
API_DOMAIN=api.envoylabs.us

# Security
JWT_SECRET=generate_a_random_secret_key_here
SESSION_SECRET=generate_another_random_secret_here

# CORS
CORS_ORIGIN=https://envoylabs.us,https://www.envoylabs.us
