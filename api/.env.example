NODE_ENV=production
PORT=4000

# Database
DATABASE_URL=postgresql://envoy:password@postgres:5432/envoydb

# Redis
REDIS_URL=redis://redis:6379

# Google Cloud Storage
GCP_PROJECT_ID=envoylabs
GCS_BUCKET_NAME=envoylabs-media

# Security
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here

# CORS
CORS_ORIGIN=https://envoylabs.us,https://www.envoylabs.us

# API
API_VERSION=v1
